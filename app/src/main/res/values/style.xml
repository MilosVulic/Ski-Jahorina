<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/alpineNavy</item>
        <item name="colorPrimaryDark">@color/alpineNavyDark</item>
        <item name="colorAccent">@color/alpineAccent</item>
        <item name="colorSecondary">@color/hubLinkColor</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/alpineNavy</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Customizing ripple effect for the layouts within the settings menu  -->
    <style name="AppTheme.SettingsFragmentRipple">
        <item name="colorControlHighlight">@color/colorRippleEnteringElements</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:navigationBarColor">@color/alpineNavy</item>
        <item name="android:statusBarColor">@color/alpineNavy</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Widget.SkiJahorina.FilterChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_background_selector</item>
        <item name="chipStrokeColor">@color/chipOutlineColor</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipMinHeight">32dp</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.SkiJahorina.FilterChip.Compact" parent="Widget.SkiJahorina.FilterChip">
        <item name="chipMinHeight">28dp</item>
        <item name="android:textSize">12sp</item>
        <item name="chipCornerRadius">14dp</item>
    </style>

    <!-- Style for onBoarding screens -->
    <style name="AppTheme.NoActionBarNonTransparent.Nesto">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Style used for setting pin and entering pin -->
    <style name="AppTheme.NoActionBarNonTransparent">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="AppTheme.NoActionBar.NoActionBar" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Customizing ripple effect for the buttons for the entering pin/setting pin  -->
    <style name="AppTheme.ApplicationRipple">
        <item name="colorControlHighlight">@color/colorRippleEnteringElements</item>
        <item name="android:background">?selectableItemBackgroundBorderless</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="CustomSearchView" parent="Widget.AppCompat.SearchView">
        <!-- Set the text color -->
        <item name="android:textColor">#ffffff</item>
        <item name="android:queryHint">#ffffff</item>
    </style>
</resources>