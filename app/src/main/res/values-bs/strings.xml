    <!-- Help center -->
    <string name="help_center_faq">FAQ</string>
    <string name="help">Help Center</string>
    <string name="help_center_question1">Koje aktivnosti osim skijanja postoje u Ski centru Jahorina?</string>
    <string name="help_center_answer1">U Ski centru Jahorina posjetitelji mogu uživati u aktivnostima poput krpljanja, sanjkanja, slikovitih vožnja žičarom i opuštanja u obližnjim barovima i restoranima nakon dana na stazama.</string>
    <string name="help_center_question2">Postoji li opcija za noćno skijanje?</string>
    <string name="help_center_answer2">Da, noćno skijanje je dostupno na stazi Poljice u Ski centru Jahorina od 18:00 do 21:00, pružajući jedinstveno večernje iskustvo na dobro osvijetljenoj stazi.</string>
    <string name="help_center_question3">Šta da radim u slučaju povrede na skijaškim stazama?</string>
    <string name="help_center_answer3">U slučaju povrede obavezno se obratite gorskoj službi spašavanja.
 Oni će intervenisati na licu mesta i prevesti vas u zvaničnu medicinsku ustanovu na skijalištu. Kontakt broj možete pronaći u rubrici korisnih informacija.</string>
    <string name="help_center_question4">Koje je radno vrijeme skijališta tokom skijaške sezone?</string>
    <string name="help_center_answer4">Skijalište radi od 9:00 do 16:00 tokom ski sezone za dnevno skijanje, a nudi i noćno skijanje od 18:00 do 21:00.</string>

