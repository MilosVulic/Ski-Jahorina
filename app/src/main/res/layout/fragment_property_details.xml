<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="@color/colorBackground"

    android:clipToPadding="false"

    android:overScrollMode="never"

    android:paddingTop="?android:attr/actionBarSize"

    android:paddingBottom="24dp">



    <LinearLayout

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:paddingTop="8dp">



        <com.google.android.material.card.MaterialCardView

            android:id="@+id/cardViewApartmentPic1"

            android:layout_width="match_parent"

            android:layout_height="220dp"

            android:layout_marginStart="16dp"

            android:layout_marginEnd="16dp"

            app:cardCornerRadius="18dp"

            app:cardElevation="2dp"

            app:strokeColor="@color/chipOutlineColor"

            app:strokeWidth="1dp">



            <ImageView

                android:id="@+id/imageViewPic1"

                android:layout_width="match_parent"

                android:layout_height="match_parent"

                android:contentDescription="@null"

                android:scaleType="centerCrop"

                tools:src="@drawable/picture_apartment" />

        </com.google.android.material.card.MaterialCardView>



        <LinearLayout

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginStart="16dp"

            android:layout_marginTop="8dp"

            android:layout_marginEnd="16dp"

            android:orientation="horizontal">



            <com.google.android.material.card.MaterialCardView

                android:id="@+id/cardViewApartmentPic2"

                android:layout_width="0dp"

                android:layout_height="72dp"

                android:layout_marginEnd="6dp"

                android:layout_weight="1"

                app:cardCornerRadius="12dp"

                app:cardElevation="0dp"

                app:strokeColor="@color/chipOutlineColor"

                app:strokeWidth="1dp">



                <ImageView

                    android:id="@+id/imageViewPic2"

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:contentDescription="@null"

                    android:scaleType="centerCrop"

                    tools:src="@drawable/picture_apartment" />

            </com.google.android.material.card.MaterialCardView>



            <com.google.android.material.card.MaterialCardView

                android:id="@+id/cardViewApartmentPic3"

                android:layout_width="0dp"

                android:layout_height="72dp"

                android:layout_marginEnd="6dp"

                android:layout_weight="1"

                app:cardCornerRadius="12dp"

                app:cardElevation="0dp"

                app:strokeColor="@color/chipOutlineColor"

                app:strokeWidth="1dp">



                <ImageView

                    android:id="@+id/imageViewPic3"

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:contentDescription="@null"

                    android:scaleType="centerCrop"

                    tools:src="@drawable/picture_apartment" />

            </com.google.android.material.card.MaterialCardView>



            <com.google.android.material.card.MaterialCardView

                android:id="@+id/cardViewApartmentPic4"

                android:layout_width="0dp"

                android:layout_height="72dp"

                android:layout_weight="1"

                app:cardCornerRadius="12dp"

                app:cardElevation="0dp"

                app:strokeColor="@color/chipOutlineColor"

                app:strokeWidth="1dp">



                <FrameLayout

                    android:layout_width="match_parent"

                    android:layout_height="match_parent">



                    <ImageView

                        android:id="@+id/imageViewPic4"

                        android:layout_width="match_parent"

                        android:layout_height="match_parent"

                        android:contentDescription="@null"

                        android:scaleType="centerCrop"

                        tools:src="@drawable/picture_apartment" />



                    <TextView

                        android:id="@+id/textViewForImageView4"

                        android:layout_width="match_parent"

                        android:layout_height="match_parent"

                        android:background="#990F172A"

                        android:gravity="center"

                        android:text="+3"

                        android:textColor="@color/colorWhite"

                        android:textSize="18sp"

                        android:textStyle="bold"

                        android:visibility="gone"

                        tools:visibility="visible" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>



        <com.google.android.material.card.MaterialCardView

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginStart="16dp"

            android:layout_marginTop="16dp"

            android:layout_marginEnd="16dp"

            app:cardBackgroundColor="@color/colorCardBackgroundSettings"

            app:cardCornerRadius="18dp"

            app:cardElevation="2dp"

            app:strokeColor="@color/chipOutlineColor"

            app:strokeWidth="1dp">



            <LinearLayout

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:orientation="vertical"

                android:padding="18dp">



                <TextView

                    android:id="@+id/textViewApartmentName"

                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"

                    android:textColor="@color/alpineTextPrimary"

                    android:textSize="22sp"

                    android:textStyle="bold"

                    tools:text="Jahorina Prestige" />



                <TextView

                    android:id="@+id/textViewLocation"

                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"

                    android:layout_marginTop="6dp"

                    android:textColor="@color/alpineTextSecondary"

                    android:textSize="14sp"

                    tools:text="Near ski slopes on Jahorina" />



                <TextView

                    android:id="@+id/textViewDescription"

                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"

                    android:layout_marginTop="18dp"

                    android:text="@string/property_description"

                    android:textColor="@color/alpineTextPrimary"

                    android:textSize="16sp"

                    android:textStyle="bold" />



                <TextView

                    android:id="@+id/textViewDescriptionContent"

                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"

                    android:layout_marginTop="8dp"

                    android:ellipsize="end"

                    android:lineSpacingExtra="4dp"

                    android:maxLines="4"

                    android:textColor="@color/alpineTextSecondary"

                    android:textSize="15sp"

                    tools:text="Description text goes here." />



                <TextView

                    android:id="@+id/textViewExpandDescription"

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    android:layout_marginTop="6dp"

                    android:paddingTop="4dp"

                    android:paddingBottom="4dp"

                    android:text="@string/read_more"

                    android:textColor="@color/alpineAccent"

                    android:textSize="14sp"

                    android:textStyle="bold"

                    android:visibility="gone"

                    tools:visibility="visible" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>



        <com.google.android.material.card.MaterialCardView

            android:id="@+id/cardViewWebsite"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginStart="16dp"

            android:layout_marginTop="12dp"

            android:layout_marginEnd="16dp"

            android:clickable="true"

            android:focusable="true"

            app:cardBackgroundColor="@color/colorCardBackgroundSettings"

            app:cardCornerRadius="16dp"

            app:cardElevation="1dp"

            app:rippleColor="@color/alpineRipple"

            app:strokeColor="@color/chipOutlineColor"

            app:strokeWidth="1dp">



            <LinearLayout

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:gravity="center_vertical"

                android:orientation="horizontal"

                android:padding="14dp">



                <FrameLayout

                    android:layout_width="44dp"

                    android:layout_height="44dp"

                    android:background="@drawable/bg_alpine_empty_icon_circle">



                    <ImageView

                        android:id="@+id/websiteIcon"

                        android:layout_width="22dp"

                        android:layout_height="22dp"

                        android:layout_gravity="center"

                        android:contentDescription="@null"

                        android:src="@drawable/ic_webpage"

                        app:tint="@color/alpineAccent" />

                </FrameLayout>



                <LinearLayout

                    android:layout_width="0dp"

                    android:layout_height="wrap_content"

                    android:layout_marginStart="14dp"

                    android:layout_weight="1"

                    android:orientation="vertical">



                    <TextView

                        android:id="@+id/textViewWebsiteLabel"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="@string/website"

                        android:textColor="@color/alpineTextPrimary"

                        android:textSize="14sp"

                        android:textStyle="bold" />



                    <TextView

                        android:id="@+id/textViewWebsiteContent"

                        android:layout_width="match_parent"

                        android:layout_height="wrap_content"

                        android:layout_marginTop="2dp"

                        android:ellipsize="end"

                        android:maxLines="2"

                        android:textColor="@color/alpineTextSecondary"

                        android:textSize="14sp"

                        tools:text="https://jahorinaprestige.com" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>



        <com.google.android.material.card.MaterialCardView

            android:id="@+id/cardViewPhoneNumber"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginStart="16dp"

            android:layout_marginTop="8dp"

            android:layout_marginEnd="16dp"

            android:clickable="true"

            android:focusable="true"

            app:cardBackgroundColor="@color/colorCardBackgroundSettings"

            app:cardCornerRadius="16dp"

            app:cardElevation="1dp"

            app:rippleColor="@color/alpineRipple"

            app:strokeColor="@color/chipOutlineColor"

            app:strokeWidth="1dp">



            <LinearLayout

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:gravity="center_vertical"

                android:orientation="horizontal"

                android:padding="14dp">



                <FrameLayout

                    android:layout_width="44dp"

                    android:layout_height="44dp"

                    android:background="@drawable/bg_alpine_empty_icon_circle">



                    <ImageView

                        android:id="@+id/phoneIcon"

                        android:layout_width="22dp"

                        android:layout_height="22dp"

                        android:layout_gravity="center"

                        android:contentDescription="@null"

                        android:src="@drawable/ic_phone"

                        app:tint="@color/alpineAccent" />

                </FrameLayout>



                <LinearLayout

                    android:layout_width="0dp"

                    android:layout_height="wrap_content"

                    android:layout_marginStart="14dp"

                    android:layout_weight="1"

                    android:orientation="vertical">



                    <TextView

                        android:id="@+id/textViewPhoneLabel"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="@string/phone"

                        android:textColor="@color/alpineTextPrimary"

                        android:textSize="14sp"

                        android:textStyle="bold" />



                    <TextView

                        android:id="@+id/textViewPhoneContent"

                        android:layout_width="match_parent"

                        android:layout_height="wrap_content"

                        android:layout_marginTop="2dp"

                        android:textColor="@color/alpineTextSecondary"

                        android:textSize="14sp"

                        tools:text="+387 65 904 660" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>



        <com.google.android.material.card.MaterialCardView

            android:id="@+id/cardViewEmail"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginStart="16dp"

            android:layout_marginTop="8dp"

            android:layout_marginEnd="16dp"

            android:clickable="true"

            android:focusable="true"

            app:cardBackgroundColor="@color/colorCardBackgroundSettings"

            app:cardCornerRadius="16dp"

            app:cardElevation="1dp"

            app:rippleColor="@color/alpineRipple"

            app:strokeColor="@color/chipOutlineColor"

            app:strokeWidth="1dp">



            <LinearLayout

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:gravity="center_vertical"

                android:orientation="horizontal"

                android:padding="14dp">



                <FrameLayout

                    android:layout_width="44dp"

                    android:layout_height="44dp"

                    android:background="@drawable/bg_alpine_empty_icon_circle">



                    <ImageView

                        android:id="@+id/emailIcon"

                        android:layout_width="22dp"

                        android:layout_height="22dp"

                        android:layout_gravity="center"

                        android:contentDescription="@null"

                        android:src="@drawable/ic_email"

                        app:tint="@color/alpineAccent" />

                </FrameLayout>



                <LinearLayout

                    android:layout_width="0dp"

                    android:layout_height="wrap_content"

                    android:layout_marginStart="14dp"

                    android:layout_weight="1"

                    android:orientation="vertical">



                    <TextView

                        android:id="@+id/textViewEmailLabel"

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="@string/email"

                        android:textColor="@color/alpineTextPrimary"

                        android:textSize="14sp"

                        android:textStyle="bold" />



                    <TextView

                        android:id="@+id/textViewEmailContent"

                        android:layout_width="match_parent"

                        android:layout_height="wrap_content"

                        android:layout_marginTop="2dp"

                        android:ellipsize="end"

                        android:maxLines="2"

                        android:textColor="@color/alpineTextSecondary"

                        android:textSize="14sp"

                        tools:text="info@jahorinaprestige.com" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>



    </LinearLayout>

</androidx.core.widget.NestedScrollView>


